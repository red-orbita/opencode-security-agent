{
  "schema_version": "1.1",
  "description": "OpenCode Security Agent Indicators of Compromise (IOCs). Patterns, paths, and domains known to be associated with skill/MCP attacks. Maintained locally so runtime protection works offline.",
  "last_updated": "2026-04-22",

  "sensitive_paths": {
    "description": "File paths a skill should almost never touch unless that's its explicit purpose.",
    "patterns": [
      "~/.ssh/",
      "~/.ssh/id_rsa",
      "~/.ssh/id_ed25519",
      "~/.ssh/config",
      "~/.aws/credentials",
      "~/.aws/config",
      "~/.gnupg/",
      "~/.config/gh/hosts.yml",
      "~/.config/opencode/",
      "~/.config/claude/",
      "~/.netrc",
      "~/.pgpass",
      "~/.docker/config.json",
      "~/.kube/config",
      "~/.npmrc",
      "~/.bash_history",
      "~/.zsh_history",
      "~/.mysql_history",
      "~/.psql_history",
      "/etc/shadow",
      "/etc/passwd",
      "/etc/sudoers"
    ],
    "regex_patterns": [
      "\\.env(\\.|$)",
      "(?i)credentials?\\.json",
      "(?i)secrets?\\.(json|ya?ml|env)",
      "(?i)api[_-]?keys?\\.(json|txt|env)",
      "(?i)private[_-]?key"
    ]
  },

  "sensitive_env_vars": {
    "description": "Environment variables commonly containing secrets.",
    "patterns": [
      "AWS_SECRET_ACCESS_KEY",
      "AWS_SESSION_TOKEN",
      "ANTHROPIC_API_KEY",
      "OPENAI_API_KEY",
      "GITHUB_TOKEN",
      "GH_TOKEN",
      "STRIPE_SECRET_KEY",
      "DATABASE_URL",
      "SUPABASE_SERVICE_ROLE_KEY",
      "CLOUDFLARE_API_TOKEN",
      "SLACK_BOT_TOKEN",
      "DISCORD_BOT_TOKEN",
      "SENDGRID_API_KEY",
      "TWILIO_AUTH_TOKEN",
      "GOOGLE_APPLICATION_CREDENTIALS"
    ],
    "regex_patterns": [
      "(?i).*_API_KEY$",
      "(?i).*_SECRET$",
      "(?i).*_TOKEN$",
      "(?i).*_PASSWORD$"
    ]
  },

  "suspicious_network": {
    "description": "Network patterns associated with exfiltration.",
    "known_malicious_domains": [
      {
        "domain": "giftshop.club",
        "incident": "Postmark MCP backdoor (v1.0.16, Sept 2025)",
        "reference": "https://thehackernews.com/2025/09/first-malicious-mcp-server-found.html"
      },
      {
        "domain": "evil.com",
        "incident": "Generic testing domain commonly used in attack simulations",
        "reference": "https://en.wikipedia.org/wiki/Evil.com"
      },
      {
        "domain": "c2.malware-toolkit.xyz",
        "incident": "C2 infrastructure associated with malware toolkit distribution",
        "reference": "threat-intel"
      }
    ],
    "suspicious_tlds": [
      ".tk", ".ml", ".ga", ".cf", ".gq", ".xyz", ".top", ".work", ".click"
    ],
    "pastebin_style": [
      "pastebin.com", "paste.ee", "hastebin.com", "dpaste.com", "termbin.com",
      "transfer.sh", "0x0.st", "file.io", "bashupload.com",
      "ix.io", "sprunge.us", "cl1p.net", "justpaste.it", "ghostbin.com", "rentry.co"
    ],
    "suspicious_patterns": [
      "https?://\\d+\\.\\d+\\.\\d+\\.\\d+",
      "(?i)webhook\\.site",
      "(?i)requestbin",
      "(?i)ngrok\\.(io|app)",
      "(?i)serveo\\.net"
    ]
  },

  "dangerous_commands": {
    "description": "Shell command patterns indicating exfiltration, RCE, or sandbox escape.",
    "patterns": [
      "curl\\s+.*(-X\\s+POST|-d\\s|--data).*http",
      "wget\\s+.*--post-(data|file)",
      "curl\\s+.*\\|\\s*(bash|sh|zsh|python)",
      "wget\\s+.*\\|\\s*(bash|sh|zsh|python)",
      "(?i)base64\\s.*(curl|wget|nc|ncat)",
      "(?i)(^|;|\\|)\\s*(eval|exec)\\s",
      "(?i)nc\\s+-e",
      "(?i)bash\\s+-i\\s+>&\\s*/dev/tcp/",
      "(?i)python\\s+-c.*socket.*connect",
      "(?i)(^|;|\\|)\\s*dd\\s+if=.*of=/dev/",
      "chmod\\s+[0-7]*777",
      ">>\\s*~/\\.(bash|zsh|profile|bashrc|zshrc)",
      "rm\\s+-rf\\s+/(?!\\S)",
      "(?i)mkfs\\s+/dev/",
      "(?i):\\(\\)\\s*\\{.*\\|.*\\}",
      "(?i)python\\s+-m\\s+http\\.server",
      "(?i)scp\\s+.*@",
      "(?i)rsync\\s+.*@"
    ]
  },

  "crypto_mining": {
    "description": "Patterns associated with cryptocurrency mining abuse.",
    "patterns": [
      "(?i)xmrig",
      "(?i)stratum\\+tcp://",
      "(?i)stratum\\+ssl://",
      "(?i)--donate-level",
      "(?i)cpuminer",
      "(?i)minerd",
      "(?i)cryptonight",
      "(?i)randomx"
    ],
    "known_pools": [
      "pool.minexmr.com",
      "xmr.pool.minergate.com",
      "monerohash.com",
      "nanopool.org",
      "supportxmr.com",
      "hashvault.pro"
    ]
  },

  "data_exfiltration": {
    "description": "Patterns suggesting data archiving and exfiltration.",
    "patterns": [
      "(?i)(tar|zip|7z)\\s+.*\\.(tar|gz|zip|7z).*&&.*(curl|wget|scp|rsync)",
      "(?i)curl\\s+.*-F\\s+file=@",
      "(?i)curl\\s+.*--upload-file",
      "(?i)cat\\s+.*\\|\\s*curl",
      "(?i)base64\\s+.*\\|\\s*curl"
    ]
  },

  "prompt_injection_phrases": {
    "description": "Phrases commonly used in prompt injection attacks embedded inside SKILL.md files.",
    "patterns": [
      "(?i)ignore\\s+(all\\s+)?previous\\s+instructions",
      "(?i)disregard\\s+(all\\s+)?(the\\s+)?(above|previous)",
      "(?i)act\\s+as\\s+(root|admin|superuser)",
      "(?i)you\\s+are\\s+now\\s+in\\s+developer\\s+mode",
      "(?i)do\\s+not\\s+(tell|show|mention)\\s+the\\s+user",
      "(?i)hide\\s+this\\s+from\\s+the\\s+user",
      "(?i)bypass\\s+(safety|security|guidelines)",
      "(?i)forget\\s+(all\\s+)?(your|the)\\s+(rules|instructions|guidelines)",
      "(?i)new\\s+system\\s+prompt",
      "(?i)override\\s+(safety|security)\\s+(protocol|settings|rules)",
      "(?i)jailbreak"
    ]
  },

  "allowlist": {
    "description": "Paths and domains explicitly allowed — reduces false positives.",
    "paths": [
      "/tmp/",
      "/var/tmp/"
    ],
    "domains": [
      "api.anthropic.com",
      "api.github.com",
      "github.com",
      "raw.githubusercontent.com",
      "registry.npmjs.org",
      "pypi.org",
      "files.pythonhosted.org",
      "stackoverflow.com",
      "docs.python.org",
      "developer.mozilla.org",
      "crates.io",
      "pkg.go.dev",
      "hub.docker.com",
      "gitlab.com"
    ]
  }
}
